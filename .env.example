# Portal Ferramentaria — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com suas credenciais reais
# NUNCA commite o arquivo .env no repositório

# Supabase (obter em: https://app.supabase.com → Seu Projeto → Settings → API)
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-key-aqui

# Apenas se usar o MCP Server do Supabase localmente
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_KEY=sua-service-role-key-aqui
